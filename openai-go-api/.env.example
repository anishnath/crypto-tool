PORT=8084

# Logging: info (default) | debug | warn | error
LOG_LEVEL=info

# Layer 3: runtime policy
DEFAULT_MODEL=mimo-v2.5
MODEL_CATALOG_PATH=config/models.yaml

# Layer 1: provider credentials
OPENAI_API_KEY=sk-your-openai-key
MIMO_API_KEY=your-mimo-key

# D1 billing (optional — logs to Cloudflare D1 when token is set)
D1_BILLING_ENABLED=true
CLOUDFLARE_ACCOUNT_ID=7e50090f0972664d8e6985f1e83131a3
D1_DATABASE_ID=b146fd57-6fcc-4847-8b3f-17a9e747758b
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# Client identity headers (sent by your app on each AI call)
# X-User-Id:       Google user id when logged in (matches users.id in D1)
# X-Anonymous-Id:  stable UUID from localStorage for guests
# X-Tool-Id:       optional slug for analytics (e.g. integral-calculator)
# Authorization:   Bearer llm_<secret> for per-user API keys (llm_user_api_keys table)

# AI monthly token quotas — source of truth is D1 table ai_plans (migration 0004).
# These env vars are fallback only when ai_plans cannot be read.
AI_QUOTA_ENABLED=true
AI_QUOTA_GUEST=20000
AI_QUOTA_FREE=200000
AI_QUOTA_PRO=2000000

# Dodo Payments — official Go SDK: github.com/dodopayments/dodopayments-go
# https://pkg.go.dev/github.com/dodopayments/dodopayments-go
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_KEY=
DODO_PAYMENTS_MODE=test
# Optional override (SDK also reads DODO_PAYMENTS_BASE_URL)
# DODO_PAYMENTS_API_BASE=https://test.dodopayments.com
DODO_PRODUCT_PRO_MONTHLY=
DODO_PRODUCT_PRO_YEARLY=
BILLING_INTERNAL_SECRET=

# Schema: migrations/0005_dodo_subscriptions.sql | Docs: db/SUBSCRIPTIONS.md
